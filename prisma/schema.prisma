// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  relationMode = "prisma"
}

model User {
  id               Int            @id @default(autoincrement())
  uid              String         @unique @db.VarChar(40)
  name             String?        @db.VarChar(255)
  username         String?        @db.VarChar(255)
  email            String?        @db.VarChar(255)
  password         String?        @db.LongText
  isVerified       Boolean        @default(false)
  billing_address  String?        @db.LongText
  shipping_address String?        @db.LongText
  createdAt        DateTime       @default(now()) @db.DateTime(0)
  updatedAt        DateTime       @updatedAt @db.DateTime(0)
  Transactions     Transactions[]
  Orders           Orders[]

  @@map("User")
}

model Admin {
  id        Int      @id @default(autoincrement())
  uid       String   @unique @db.VarChar(40)
  createdAt DateTime @default(now()) @db.DateTime(0)
  updatedAt DateTime @updatedAt @db.DateTime(0)

  @@map("Admin")
}

model Images {
  id             Int              @id @default(autoincrement())
  name           String           @db.MediumText
  img_url        String?          @db.LongText
  fileType       String?          @db.VarChar(255)
  createdAt      DateTime         @default(now()) @db.DateTime(0)
  updatedAt      DateTime         @updatedAt @db.DateTime(0)
  Category       Category[]
  Product_Images Product_Images[]

  @@map("Images")
}

model Product_Images {
  id        Int      @id @default(autoincrement())
  productId String   @db.VarChar(255)
  imageId   Int
  createdAt DateTime @default(now()) @db.DateTime(0)
  updatedAt DateTime @updatedAt @db.DateTime(0)
  image     Images   @relation(fields: [imageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product   Product  @relation(fields: [productId], references: [uid], onDelete: NoAction, onUpdate: NoAction)

  @@index([imageId])
  @@index([productId])
  @@map("Product_Images")
}

model Product {
  id               Int                @id @default(autoincrement())
  uid              String             @unique @db.VarChar(255)
  categoryId       String?            @db.VarChar(255)
  parentCategoryId String?            @db.VarChar(255)
  name             String?            @db.VarChar(255)
  // price            Float
  description      String?            @db.LongText
  // units            Int                @default(0)
  isActive         Boolean            @default(true)
  isDeleted        Boolean            @default(false)
  createdAt        DateTime           @default(now()) @db.DateTime(0)
  updatedAt        DateTime           @updatedAt @db.DateTime(0)
  category         Category?          @relation(fields: [categoryId], references: [uid], onDelete: Cascade, onUpdate: NoAction)
  discount         Product_Discount?
  linkedCarts      Cart[]
  images           Product_Images[]
  variants         Product_Variants[]

  @@index([categoryId])
  @@map("Product")
}

model Product_Variants {
  id             Int      @id @default(autoincrement())
  uid            String   @unique @db.VarChar(255)
  productId      String   @db.VarChar(255)
  name           String?  @db.VarChar(255)
  price          Float
  units          Int      @default(0)
  specifications Json?
  createdAt      DateTime @default(now()) @db.DateTime(0)
  updatedAt      DateTime @updatedAt @db.DateTime(0)
  product        Product  @relation(fields: [productId], references: [uid], onDelete: Cascade, onUpdate: NoAction)

  @@index([productId])
  @@map("Product_Variants")
}

model Coupon {
  id             Int       @id @default(autoincrement())
  code           String    @db.VarChar(50)
  name           String    @db.MediumText
  coupon_type    String    @db.VarChar(20)
  product_list   Json?
  category_list  Json?
  discount_value Float
  discount_type  String    @db.VarChar(50)
  startDate      DateTime? @db.DateTime(0)
  endDate        DateTime? @db.DateTime(0)
  limit          Int
  usage          Int       @default(0)
  status         String    @default("Active") @db.VarChar(20)
  deletedAt      DateTime? @db.DateTime(0)
  createdAt      DateTime  @default(now()) @db.DateTime(0)
  updatedAt      DateTime  @updatedAt @db.DateTime(0)

  @@map("Coupon")
}

model Product_Discount {
  id        Int       @id @default(autoincrement())
  productId String    @unique @db.VarChar(255)
  price     Int
  startDate DateTime? @db.DateTime(0)
  endDate   DateTime? @db.DateTime(0)
  createdAt DateTime  @default(now()) @db.DateTime(0)
  updatedAt DateTime  @updatedAt @db.DateTime(0)
  product   Product   @relation(fields: [productId], references: [uid], onDelete: NoAction, onUpdate: NoAction)

  @@map("Product_Discount")
}

model Category {
  id                      Int        @id @default(autoincrement())
  uid                     String     @unique @db.VarChar(255)
  name                    String?    @db.VarChar(255)
  imageId                 Int?
  // category_specifications Json?
  parentId                String?    @db.VarChar(255)
  sortOrder               Int?
  createdAt               DateTime   @default(now()) @db.DateTime(0)
  updatedAt               DateTime   @updatedAt @db.DateTime(0)
  image                   Images?    @relation(fields: [imageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product                 Product[]
  subCategories           Category[] @relation("CategoryToSubCategory")
  parentCategory          Category?  @relation("CategoryToSubCategory", fields: [parentId], references: [uid], onDelete: NoAction, onUpdate: NoAction)

  @@index([imageId])
  @@index([parentId])
  @@index([uid])
  @@map("Category")
}

model Cart {
  id                       Int      @id @default(autoincrement())
  productId                String?  @db.VarChar(255)
  uid                      String   @db.VarChar(255)
  units                    String?  @db.VarChar(255)
  specifications           Json?
  unit_price               Float?
  total_amount             Float?
  orderId                  String?  @db.VarChar(255)
  ordered                  Boolean  @default(false)
  isTechnicianRequired     Boolean  @default(false)
  isTechnicianRequiredCost Float    @default(0)
  coupon_used              Boolean  @default(false)
  coupon_code              String?  @db.VarChar(255)
  createdAt                DateTime @default(now()) @db.DateTime(0)
  updatedAt                DateTime @updatedAt @db.DateTime(0)
  product                  Product? @relation(fields: [productId], references: [uid], onDelete: NoAction, onUpdate: NoAction)
  order                    Orders?  @relation(fields: [orderId], references: [orderId], onDelete: NoAction, onUpdate: NoAction)

  @@index([productId])
  @@index([orderId])
  @@map("Cart")
}

model Orders {
  id              Int           @id @default(autoincrement())
  uid             String?       @db.VarChar(40)
  orderId         String        @unique @db.VarChar(255)
  status          String        @default("Pending") @db.VarChar(255)
  paymentStatus   String        @default("Pending") @db.VarChar(255)
  contact_Info    Json?
  billing_address Json?
  deliveryType    String?       @default("Pick-up") @db.VarChar(50)
  deliveryCost    Float?        @default(0)
  createdAt       DateTime      @default(now()) @db.DateTime(0)
  updatedAt       DateTime      @updatedAt @db.DateTime(0)
  cart            Cart[]
  transactions    Transactions?
  user            User?         @relation(fields: [uid], references: [uid], onDelete: NoAction, onUpdate: NoAction)

  @@index([uid])
  @@map("Orders")
}

model Transactions {
  id        Int      @id @default(autoincrement())
  orderId   String   @unique @db.VarChar(40)
  uid       String?  @db.VarChar(255)
  reference String   @db.VarChar(255)
  amount    Float
  status    String?  @default("Pending") @db.VarChar(50)
  createdAt DateTime @default(now()) @db.DateTime(0)
  updatedAt DateTime @updatedAt @db.DateTime(0)
  order     Orders   @relation(fields: [orderId], references: [orderId], onDelete: NoAction, onUpdate: NoAction)
  customer  User?    @relation(fields: [uid], references: [uid], onDelete: NoAction, onUpdate: NoAction)

  @@index([uid])
  @@map("Transactions")
}

model ExtraPayments {
  id    Int     @id @default(autoincrement())
  name  String? @db.VarChar(255)
  price Float?

  @@map("ExtraPayments")
}

model ShippingAddress {
  id              Int      @id @default(autoincrement())
  uid             String?  @db.VarChar(40)
  shippingAddress String?  @db.MediumText
  billingAddress  String?  @db.MediumText
  createdAt       DateTime @default(now()) @db.DateTime(0)
  updatedAt       DateTime @updatedAt @db.DateTime(0)

  @@map("ShippingAddress")
}
